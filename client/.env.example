# Panggon Mikir — Client environment variables
# Vite reads VITE_* vars at build time.

# API base URL — for dev (Vite at :5173 talking to API at :3007), set explicit URL.
# For Docker prod (client served from same origin), use '/api'.
VITE_API_URL=http://localhost:3007/api
VITE_APP_NAME=Panggon Mikir

# Google OAuth Client ID (publicly visible in JS bundle — that's expected for OAuth client IDs)
# Get from https://console.cloud.google.com → OAuth 2.0 Client (Web)
VITE_GOOGLE_CLIENT_ID=
