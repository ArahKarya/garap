# ============================================================================
# Panggon Mikir — Caddy reverse-proxy snippet
#
# Tambahkan blok berikut ke /etc/caddy/Caddyfile (atau file include) di RPi5,
# lalu reload: sudo systemctl reload caddy
#
# Caddy otomatis terbitkan TLS via Let's Encrypt — pastikan domain
# panggonmikir.arahkarya.com sudah resolve ke IP RPi5.
# ============================================================================

panggonmikir.arahkarya.com {
    encode zstd gzip

    # Healthcheck Caddy upstream
    @health {
        path /api/health
    }
    handle @health {
        reverse_proxy localhost:3007
    }

    # Static assets — cache aggressive
    @static {
        path /icons/* /assets/* /favicon.ico /manifest.json
    }
    handle @static {
        reverse_proxy localhost:3007 {
            header_down Cache-Control "public, max-age=31536000, immutable"
        }
    }

    # Bull Board (admin only — auth dipasang di app layer)
    handle /admin/queues* {
        reverse_proxy localhost:3007
    }

    # API + SPA fallback semuanya ke app
    reverse_proxy localhost:3007 {
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    log {
        output file /var/log/caddy/panggonmikir.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
