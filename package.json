{
  "name": "garap",
  "version": "0.1.0",
  "private": true,
  "description": "Panggon Mikir — Personal second brain (task, project, document, link, note) — built on ArahKarya framework",
  "author": "Yayang Setya Nugroho",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:client": "pnpm --filter @garap/client dev",
    "dev:server": "pnpm --filter @garap/server dev",
    "dev:worker": "pnpm --filter @garap/server dev:worker",
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @garap/shared build",
    "start": "pnpm --filter @garap/server start",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @garap/server db:migrate",
    "db:seed": "pnpm --filter @garap/server db:seed",
    "db:reset": "pnpm --filter @garap/server db:reset",
    "new:module": "node scripts/new-module.mjs",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.9.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  }
}
