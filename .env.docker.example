# ============================================================================
# Panggon Mikir — Docker Environment Variables
# Copy ke .env, isi nilai, lalu: docker compose up -d --build
# ============================================================================

# === PostgreSQL ===
POSTGRES_USER=panggonmikir
POSTGRES_PASSWORD=panggonmikir_secret_2026
POSTGRES_DB=panggonmikir_db
POSTGRES_PORT=5439

# === Redis ===
REDIS_PORT_HOST=6380

# === Aplikasi ===
APP_PORT=3007
APP_URL=https://panggonmikir.arahkarya.com
CORS_ORIGIN=https://panggonmikir.arahkarya.com

# === JWT — generate: openssl rand -base64 48 ===
JWT_ACCESS_SECRET=replace-with-random-min-32-chars-xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-with-another-random-min-32-chars-yyyyyyyyyy

# === Google OAuth ===
# Buat di https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI: https://panggonmikir.arahkarya.com/api/auth/google/callback
#                          (+ http://localhost:3007/api/auth/google/callback untuk dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://panggonmikir.arahkarya.com/api/auth/google/callback

# === Allowed Emails (comma-separated) ===
# Solo-user app — biasanya 1 email. Yang tidak terdaftar akan ditolak login.
ALLOWED_EMAILS=yayang.nugroho.s@gmail.com

# === Seed admin (fallback non-Google login) ===
SEED_ADMIN_EMAIL=admin@panggonmikir.local
SEED_ADMIN_PASSWORD=ChangeMe!2026

AUTO_SEED=true
