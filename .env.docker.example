# ============================================================================
# Garap — Docker Environment Variables
# Copy ke .env, isi nilai, lalu: docker compose up -d --build
# ============================================================================

# === PostgreSQL ===
POSTGRES_USER=garap
POSTGRES_PASSWORD=garap_secret_2026
POSTGRES_DB=garap_db
POSTGRES_PORT=5439

# === Redis ===
REDIS_PORT_HOST=6380

# === Aplikasi ===
APP_PORT=3007
APP_URL=https://garap.arahkarya.com
CORS_ORIGIN=https://garap.arahkarya.com

# === JWT — generate: openssl rand -base64 48 ===
JWT_ACCESS_SECRET=replace-with-random-min-32-chars-xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-with-another-random-min-32-chars-yyyyyyyyyy

# === Allowed Emails (comma-separated) ===
# Solo-user app — biasanya 1 email. Yang tidak terdaftar akan ditolak login/daftar.
# PUBLIC_SIGNUP=true → siapa pun boleh daftar (email/password). false = hanya ALLOWED_EMAILS.
PUBLIC_SIGNUP=false
ALLOWED_EMAILS=yayang.nugroho.s@gmail.com

# === Seed admin (login email/password) ===
SEED_ADMIN_EMAIL=admin@garap.local
SEED_ADMIN_PASSWORD=ChangeMe!2026

AUTO_SEED=true
