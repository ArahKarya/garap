# ============================================================================
# Panggon Mikir — nginx reverse-proxy site config
#
# Pasang di RPi5:
#   sudo cp nginx/panggonmikir-arahkarya.conf.example /etc/nginx/sites-available/panggonmikir-arahkarya
#   sudo ln -s /etc/nginx/sites-available/panggonmikir-arahkarya /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# DNS:
#   Tambahkan di Cloudflare: CNAME panggonmikir → arahkarya.com (Proxied: ON)
#
# TLS cert (Cloudflare Origin Certificate):
#   Pakai cert yang sama dengan arahkarya.com — Cloudflare origin cert biasanya
#   wildcard *.arahkarya.com. Kalau bukan wildcard, generate cert baru di
#   Cloudflare → SSL/TLS → Origin Server, taruh di /etc/nginx/ssl/.
# ============================================================================

server {
    listen 80;
    server_name panggonmikir.arahkarya.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name panggonmikir.arahkarya.com;

    # Reuse existing Cloudflare origin cert (atau ganti ke wildcard *.arahkarya.com).
    ssl_certificate     /etc/nginx/ssl/arahkarya.crt;
    ssl_certificate_key /etc/nginx/ssl/arahkarya.key;

    # ── Cloudflare Real IP (sama persis dengan arahkarya.com) ─────────────
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 131.0.72.0/22;
    real_ip_header CF-Connecting-IP;

    # 50MB untuk upload file lokal ke /api/documents/upload.
    client_max_body_size 50M;

    # Static assets (icons, fonts) — cache lebih agresif.
    location ~* ^/(icons|assets)/ {
        proxy_pass http://127.0.0.1:3007;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Bull Board admin UI (di-protect oleh app middleware).
    location /admin/queues {
        proxy_pass http://127.0.0.1:3007;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API + SPA fallback semuanya ke app container di port 3007.
    location / {
        proxy_pass http://127.0.0.1:3007;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 60s;
        proxy_send_timeout    60s;
        proxy_read_timeout    60s;
    }

    access_log /var/log/nginx/panggonmikir-access.log;
    error_log  /var/log/nginx/panggonmikir-error.log;
}
